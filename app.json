{
  "expo": {
    "name": "PawQuest",
    "slug": "pawquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pawquest",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ugurbakisuzun.pawquest",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "PawQuest uses your microphone so you can describe your dog's behaviour hands-free during training sessions.",
        "NSSpeechRecognitionUsageDescription": "PawQuest converts your voice to text so the AI coach can analyse your training session in real time."
      }
    },
    "android": {
      "package": "com.ugurbakisuzun.pawquest",
      "versionCode": 1,
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#0F0B2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0B2E",
          "dark": {
            "backgroundColor": "#0F0B2E"
          }
        }
      ],
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5280bbef-b580-48ae-bb05-e137b842fc2e"
      }
    }
  }
}
