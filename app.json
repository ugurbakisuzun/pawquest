{
  "expo": {
    "name": "Pawlo",
    "slug": "pawquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pawlo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ugurbakisuzun.pawlo",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Pawlo uses your microphone so you can describe your dog's behaviour hands-free during training sessions.",
        "NSSpeechRecognitionUsageDescription": "Pawlo converts your voice to text so Pawlo (your dog's teacher) can give you instant feedback on every session.",
        "NSLocationWhenInUseUsageDescription": "Pawlo tracks your location during dog walks to measure distance and award XP."
      }
    },
    "android": {
      "package": "com.ugurbakisuzun.pawlo",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0F0B2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0B2E",
          "dark": {
            "backgroundColor": "#0F0B2E"
          }
        }
      ],
      "expo-speech-recognition",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Pawlo tracks your location during dog walks to measure distance and award XP."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FAC775",
          "defaultChannel": "training"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5280bbef-b580-48ae-bb05-e137b842fc2e"
      }
    }
  }
}
